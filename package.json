{
  "name": "lp-site",
  "version": "1.0.0",
  "description": "flat-file blog starter",
  "main": "index.js",
  "scripts": {
    "build": "gatsby build",
    "check-format": "npm run pretty -- --list-different",
    "clean": "rm -rf dist && gatsby clean",
    "commit": "npx git-cz",
    "dev": "npx browserslist@latest --update-db && gatsby develop",
    "format": "npm run pretty -- --write",
    "lint": "eslint --ignore-path .gitignore --ext .js --ext .jsx .",
    "pretty": "prettier --ignore-path .gitignore \"**/*.+(js|json|md)\"",
    "serve": "gatsby serve",
    "test": "jest",
    "coverage": "jest --config jest.config.js",
    "snapshot": "npm test -- -u",
    "update-tests": "jest -- -u",
    "validate": "npm-run-all --parallel check-format lint",
    "build:prefix": "gatsby build --prefix-paths",
    "deploy": "gatsby build --prefix-paths && gh-pages -d public -r https://$GH_TOKEN@github.com/Loonz206/lp-site.git",
    "prepare": "npm run snyk-protect",
    "snyk-protect": "snyk-protect",
    "cy:run": "npx cypress run",
    "cy:open": "npx cypress open",
    "e2e:test": "start-server-and-test dev http://localhost:8000 cy:run",
    "e2e:open": "start-server-and-test dev http://localhost:8000 cy:open"
  },
  "keywords": [
    "gatsby"
  ],
  "author": "loonz206 <@loonz206>",
  "license": "ISC",
  "dependencies": {
    "@snyk/protect": "^1.1303.1",
    "dotenv": "^16.4.7",
    "gatsby": "^5.16.1",
    "gatsby-plugin-react-svg": "^3.3.0",
    "gatsby-plugin-sass": "^6.16.0",
    "gatsby-source-filesystem": "^5.16.0",
    "gatsby-transformer-remark": "^6.16.0",
    "prop-types": "^15.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-redux": "^9.2.0",
    "redux": "^5.0.1",
    "sass": "^1.87.0"
  },
  "devDependencies": {
    "@babel/preset-typescript": "^7.27.0",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@testing-library/cypress": "^10.1.0",
    "@testing-library/jest-dom": "^6.9.0",
    "@testing-library/react": "^14.3.1",
    "babel-jest": "^29.7.0",
    "babel-preset-gatsby": "^3.16.0",
    "cypress": "^13.17.0",
    "eslint": "^8.57.1",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-cypress": "^3.5.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-sonarjs": "^0.25.1",
    "expect": "^29.7.0",
    "gh-pages": "^6.3.0",
    "husky": "^4.3.8",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^15.4.3",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.5.3",
    "react-test-renderer": "^18.3.1",
    "start-server-and-test": "^2.1.5"
  },
  "snyk": true
}
